#!/usr/bin/env bash

set -eo pipefail

export DOTFILES_DIR="${DOTFILES_DIR:-$(cd -- "$(dirname "$0")/.." &>/dev/null && pwd -P)}"

source "$DOTFILES_DIR/scripts/lib/cli.sh"
source "$DOTFILES_DIR/scripts/lib/prompt.sh"

default_excludes=(.git .local logs tmp node_modules __pycache__ .DS_Store)

usage() {
  cat <<-EOF
Usage: rput <file>

Copy local file to remote.

Options:
  [-S] Use sudo on remote server
  [--no-exclude] Do not exclude common directories (${default_excludes[*]})
EOF
  exit 1
}

while [ $# -gt 0 ]; do
  case "$1" in
    -S)
      use_sudo=1
      ;;
    --no-exclude)
      no_exclude=1
      ;;
    -*)
      usage
      ;;
    *)
      [ -n "$file" ] && abort "Only one file is supported"
      file="$1"
      ;;
  esac
  shift
done

if [ -z "$file" ]; then
  echo "A file must be specified."
  exit 1
elif [ ! -e "$file" ]; then
  echo "File $file doesn't exist."
  exit 1
fi

source "$DOTFILES_DIR/scripts/lib/clipboard.sh"
get_clipboard content

if [[ ! "$content" =~ ^.+@[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:.+$ ]]; then
  echo "Clipboard content doesn't match the format: user@ip:/path/to/file"
  exit 1
fi

# rinfo marks directories with a leading "-r "; strip it since we detect dirs locally
if [[ "$content" =~ ^\-r[[:space:]] ]]; then
  content="$(echo "$content" | sed "s/\-r //")"
fi

file="$(realpath "$file")"

if [ "$use_sudo" = 1 ]; then
  cmd=(rsync -az --rsync-path="sudo rsync")
elif [ -d "$file" ]; then
  cmd=(rsync -az)
else
  cmd=(scp)
fi

if [ -d "$file" ]; then
  local_name="$(basename "$file")"
  remote_name="$(basename "${content#*:}")"
  # If local and remote names match, the clipboard path already points to the
  # exact destination (e.g. rinfo ~/foo -> rput ~/foo), so merge contents in.
  # Otherwise the clipboard is a parent dir; let rsync create the subdir inside it.
  if [ "$local_name" = "$remote_name" ]; then
    file="${file%/}/"
  fi
  if [ -z "$no_exclude" ]; then
    for pattern in "${default_excludes[@]}"; do
      cmd+=(--exclude="$pattern")
    done
  fi
fi

echo "${cmd[@]}" "$file" "$content"

"${cmd[@]}" "$file" "$content"
