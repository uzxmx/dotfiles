#!/usr/bin/env bash

set -eo pipefail

export DOTFILES_DIR="${DOTFILES_DIR:-$(cd -- "$(dirname "$0")/.." &>/dev/null && pwd -P)}"
pip_dir="$DOTFILES_DIR/scripts/pip"

source "$DOTFILES_DIR/scripts/lib/cli.sh"

usage() {
  cat <<-EOF
Wrapper for pip utility.

Subcommands:
  i            - install (shorthand for pip install)
  m, mirror    - manage mirror
  u, uninstall - select and uninstall packages via fzf
EOF
  exit 1
}

case "$1" in
  i)
    shift
    pip install "$@"
    ;;
  m | mirror | u | uninstall)
    case "$1" in
      m)
        name="mirror"
        ;;
      u)
        name="uninstall"
        ;;
      *)
        name="$1"
        ;;
    esac
    source "$pip_dir/$name.sh"
    run "$@"
    ;;
  -h)
    usage
    ;;
  *)
    pip "$@"
    ;;
esac
