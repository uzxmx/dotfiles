#!/usr/bin/env bash

set -eo pipefail

export DOTFILES_DIR="${DOTFILES_DIR:-$(cd -- "$(dirname "$0")/.." &>/dev/null && pwd -P)}"
net_dir="$DOTFILES_DIR/scripts/net"

source "$DOTFILES_DIR/scripts/lib/cli.sh"

usage() {
  cat <<-EOF
Network utilities.

Subcommands:
  d, dns       - setup DNS servers
  b, bandwidth - measure public-internet bandwidth
EOF
  exit 1
}

case "$1" in
  d | dns | b | bandwidth)
    case "$1" in
      d)
        name="dns"
        ;;
      b)
        name="bandwidth"
        ;;
      *)
        name="$1"
    esac
    source "$net_dir/$name.sh"
    run "$@"
    ;;
  *)
    usage
    ;;
esac
