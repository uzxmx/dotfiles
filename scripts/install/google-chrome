#!/usr/bin/env bash
#
# Install google-chrome on Linux server.

set -eo pipefail

export DOTFILES_DIR="${DOTFILES_DIR:-$(cd -- "$(dirname "$0")/../.." &>/dev/null && pwd -P)}"
export DOTFILES_TARGET_DIR="${DOTFILES_TARGET_DIR:-$HOME}"

usage() {
  cat <<-EOF
Install google-chrome.

Options:
  -u        Update google-chrome
  -d <dir>  Extract to <dir> without overwriting the existing installation
EOF
  exit 1
}

update=""
install_dir=""

parse_args="
  -u)
    update=1
    ;;
  -d)
    shift
    install_dir=\"\$1\"
    ;;
  *)
    usage
    ;;
"

source "$DOTFILES_DIR/scripts/lib/install.sh"

# Chrome relies on system fonts (via fontconfig) to render pages. Without CJK
# fonts installed, printing pages that contain Korean/Chinese/Japanese text to
# PDF produces tofu boxes / garbled output. Install Noto CJK to cover them.
install_cjk_fonts() {
  if has_apt; then
    sudo apt-get install -y fonts-noto-cjk fonts-noto-cjk-extra
  elif has_yum; then
    sudo yum install -y google-noto-sans-cjk-ttc-fonts || \
      sudo yum install -y google-noto-cjk-fonts
  fi
  sudo fc-cache -f
}

if [ -z "$install_dir" ]; then
  if check_command google-chrome &> /dev/null; then
    # Already installed: still make sure CJK fonts are present, then stop
    # unless an update was requested.
    if [ -z "$update" ]; then
      install_cjk_fonts
      exit
    fi
  else
    update=""
  fi
fi

if has_apt; then
  if [ -n "$install_dir" ]; then
    path_to_save="/tmp/google-chrome-stable_current_amd64.deb"
    "$DOTFILES_DIR/bin/get" https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb "$path_to_save"
    mkdir -p "$install_dir"
    dpkg -x "$path_to_save" "$install_dir"
    echo "Chrome extracted to $install_dir"
    echo "Binary: $install_dir/opt/google/chrome/chrome"
  elif [ "$update" = "1" ]; then
    sudo apt-get -y --only-upgrade install google-chrome-stable
  else
    path_to_save="/tmp/google-chrome-stable_current_amd64.deb"
    "$DOTFILES_DIR/bin/get" https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb "$path_to_save"
    # Let it continue.
    sudo dpkg -i "$path_to_save" || true
    sudo apt install -y --fix-broken
  fi
elif has_yum; then
  if [ -n "$install_dir" ]; then
    path_to_save="/tmp/google-chrome-stable_current_x86_64.rpm"
    "$DOTFILES_DIR/bin/get" https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm "$path_to_save"
    mkdir -p "$install_dir"
    rpm2cpio "$path_to_save" | (cd "$install_dir" && cpio -idm --quiet)
    echo "Chrome extracted to $install_dir"
    echo "Binary: $install_dir/opt/google/chrome/chrome"
  elif [ "$update" = "1" ]; then
    sudo yum update -y google-chrome --nogpgcheck
  else
    path_to_save="/tmp/google-chrome-stable_current_x86_64.rpm"
    "$DOTFILES_DIR/bin/get" https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm "$path_to_save"
    sudo yum localinstall -y "$path_to_save"
  fi
else
  abort "Unsupported system"
fi

install_cjk_fonts

[ -f "$path_to_save" ] && rm "$path_to_save"
