#!/usr/bin/env python3
# TODO:
#   * auto-complete when prompting for a file path
#   * improve editing capabilities (readline)
import os
import shlex
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), '..', 'python'))

import ssh as ssh_module
import wrapper

ssh_module.check_ssh_hosts_file()
wrapper.run_original_if_required()


def prompt_string(title, default=None):
    hint = f" [{default}]" if default else ""
    value = input(f"{title}{hint}: ").strip()
    return value or default or ''


def prompt_yes_no(title, default=None):
    if default == 1:
        hint = " (Y/n)"
    elif default == 0:
        hint = " (y/N)"
    else:
        hint = " (y/n)"
    value = input(f"{title}{hint}: ").strip().upper()
    if value == 'Y':
        return True
    if value == 'N':
        return False
    return bool(default)


upload = prompt_yes_no('Upload?', default=1)
local_path = os.path.expanduser(prompt_string('Local path', '.'))
remote_path = prompt_string('Remote path', f"~/{os.path.basename(os.getcwd())}")

s = ssh_module.select_host()

command = ['rsync', '-avuz']

exclude = os.path.expanduser('~/.rsync.excludes')
if os.path.exists(exclude):
    command += ['--exclude-from', exclude]

ssh_args = ['ssh']

identity = s.get_identity()
if identity:
    ssh_args += ['-i', identity]

port = s.get_port()
if port:
    ssh_args += ['-p', port]

ssh_options = s.get_ssh_options()
if ssh_options:
    for opt in ssh_options:
        ssh_args += ['-o', opt]

command += ['-e', ' '.join(shlex.quote(a) for a in ssh_args)]

user_host = s.get_user_host()
if upload:
    command += [local_path, f"{user_host}:{remote_path}"]
else:
    command += [f"{user_host}:{remote_path}", local_path]

s.run(*command)
