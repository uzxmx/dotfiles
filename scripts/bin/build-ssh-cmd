#!/usr/bin/env python3
import os
import shlex
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), '..', 'python'))

import ssh as ssh_module

if not sys.argv[1:]:
    print("A host label is required.", file=sys.stderr)
    sys.exit(1)

s = ssh_module.select_host(sys.argv[1], caller_name='build-ssh-cmd')
if s is None:
    sys.exit(0)

command = ['ssh']

identity = s.get_identity()
if identity:
    command += ['-i', identity]

port = s.get_port()
if port:
    command += ['-p', port]

user_host = s.get_user_host()
if user_host:
    command.append(user_host)

ssh_options = s.get_ssh_options()
if ssh_options:
    for opt in ssh_options:
        command += ['-o', opt]

print(' '.join(shlex.quote(a) for a in s.build_command(*command)))
