#!/usr/bin/env bash

export DOTFILES_DIR="${DOTFILES_DIR:-$(cd -- "$(dirname "$0")/../.." &>/dev/null && pwd -P)}"

if [ "$#" -gt 0 ]; then
  exec ssh "$@"
fi

host_label=$("$DOTFILES_DIR/scripts/bin/select-ssh-host")
[ -z "$host_label" ] && exit

exec python3 "$DOTFILES_DIR/scripts/python/wrapper.py" ssh-utils ssh "$host_label"
